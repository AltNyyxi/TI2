<Window x:Class="TI2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторная работа 2. Ращеня Роман. Вариант 7" Height="750" Width="835"
        WindowStartupLocation="CenterScreen" Background="#FF2D2D2D"
        FontFamily="Segoe UI" FontSize="14" BorderBrush="#FF000000" BorderThickness="2">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#FF000000" BorderThickness="2" Background="#FF3A3A3A" 
                Margin="0,0,0,20" Padding="10">
            <TextBlock Text="Потоковый шифр LFSR: х^29 + x^2 + 1" 
                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" 
                       Foreground="#FFE0E0E0"/>
        </Border>

        <Border Grid.Row="1" BorderBrush="#FF000000" BorderThickness="2" Background="#FF3A3A3A" 
                Margin="0,0,0,20" Padding="10">
            <StackPanel>
                <Label Content="Начальное состояние (29 бит):" FontWeight="Bold" 
                       Foreground="#FFE0E0E0" Padding="0,0,0,5"/>
                <TextBox x:Name="SeedTextBox" MaxLength="29" FontFamily="Courier New" FontSize="20"
                         TextChanged="SeedTextBox_TextChanged"
                         ToolTip="Введите 29 бит (только 0 и 1)" Height="32"
                         Background="#FF1E1E1E" Foreground="#FF00FF00" 
                         BorderBrush="#FF000000" BorderThickness="2" 
                         CaretBrush="#FF00FF00"/>
                <TextBlock x:Name="CounterTextBlock" FontSize="12" Foreground="#FF888888" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="#FF000000" BorderThickness="2" Background="#FF3A3A3A" 
                Margin="0,0,0,20" Padding="10">
            <StackPanel>
                <Label Content="Выберите файл для обработки:" FontWeight="Bold" 
                       Foreground="#FFE0E0E0" Padding="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathTextBox" Grid.Column="0" IsReadOnly="True" 
                             Background="#FF1E1E1E" Foreground="#FFE0E0E0" 
                             VerticalAlignment="Center" Height="38" FontSize="14" 
                             Margin="0,0,10,0" BorderBrush="#FF000000" BorderThickness="2"/>
                    <Button x:Name="SelectFileButton" Content="Выбрать файл" Grid.Column="1"
                            Click="SelectFileButton_Click" Width="120" Height="38"
                            Background="#FF555555" Foreground="#FFE0E0E0" Cursor="Hand"
                            FontWeight="Bold" BorderBrush="#FF000000" BorderThickness="2">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="0"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Button x:Name="ProcessButton" Grid.Row="3" Content="ЗАПУСТИТЬ ОБРАБОТКУ" 
                Click="ProcessButton_Click" Background="#FF555555" Foreground="#FFE0E0E0" 
                FontSize="16" FontWeight="Bold" Height="45" Cursor="Hand"
                Margin="0,0,0,20" BorderBrush="#FF000000" BorderThickness="3">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="0"/>
                </Style>
            </Button.Resources>
        </Button>

        <StackPanel x:Name="ResultsPanel" Grid.Row="4" Visibility="Collapsed" >
            <Border BorderBrush="#FF000000" BorderThickness="2" Background="#FF3A3A3A" 
                    Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <Label Content="Исходный файл (первые 10 байт + ... + последние 10 байт):" 
                           FontWeight="Bold" Foreground="#FFE0E0E0" Padding="0,0,0,5"/>
                    <Border Background="#FF1E1E1E" BorderBrush="#FF000000" BorderThickness="2" Padding="8">
                        <TextBlock x:Name="OrigOutput" Foreground="#FF00FF00" FontFamily="Courier New" 
                                   FontSize="13" TextWrapping="Wrap" Text=""/>
                    </Border>
                </StackPanel>
            </Border>

            <Border BorderBrush="#FF000000" BorderThickness="2" Background="#FF3A3A3A" 
                    Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <Label Content="Сгенерированный ключ (первые 10 байт + ... + последние 10 байт):" 
                           FontWeight="Bold" Foreground="#FFE0E0E0" Padding="0,0,0,5"/>
                    <Border Background="#FF1E1E1E" BorderBrush="#FF000000" BorderThickness="2" Padding="8">
                        <TextBlock x:Name="KeyOutput" Foreground="#FF00FF00" FontFamily="Courier New" 
                                   FontSize="13" TextWrapping="Wrap" Text=""/>
                    </Border>
                </StackPanel>
            </Border>

            <Border BorderBrush="#FF000000" BorderThickness="2" Background="#FF3A3A3A" 
                    Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <Label Content="Результат (первые 10 байт + ... + последние 10 байт):" 
                           FontWeight="Bold" Foreground="#FFE0E0E0" Padding="0,0,0,5"/>
                    <Border Background="#FF1E1E1E" BorderBrush="#FF000000" BorderThickness="2" Padding="8">
                        <TextBlock x:Name="ResultOutput" Foreground="#FF00FF00" FontFamily="Courier New" 
                                   FontSize="13" TextWrapping="Wrap" Text=""/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>

        <ProgressBar x:Name="ProgressBar" Grid.Row="4" Height="30" Margin="0,10,0,0" 
                     Visibility="Collapsed" IsIndeterminate="True"
                     Background="#FF1E1E1E" BorderBrush="#FF000000" BorderThickness="2"/>
    </Grid>
</Window>